{
  "name": "udtl",
  "version": "0.0.1",
  "private": true,
  "description": "UDTL Customer Portal & Operations Console — monorepo (Next.js web on Vercel + shared db schema)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @udtl/web",
    "dev:web": "npm run dev -w @udtl/web",
    "build": "npm run build -w @udtl/db && npm run build -w @udtl/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run generate -w @udtl/db",
    "db:migrate": "npm run migrate -w @udtl/db",
    "db:studio": "npm run studio -w @udtl/db"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
