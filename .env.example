# =================================================================
# UDTL Customer Portal & Operations Console — environment template
# =================================================================
# Copy this file to .env.local (web) and apps/worker/.env (worker).
# Never commit real values to git.
# =================================================================

# --- Supabase (DB + Auth + Storage) ---
# Project URL — looks like https://xxxxx.supabase.co
SUPABASE_URL=
# Anon (public) key — used in browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server only, NEVER exposed to client
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection (Drizzle migrations + worker)
DATABASE_URL=postgres://postgres:[password]@db.xxxxx.supabase.co:5432/postgres

# --- FleetHunt (live truck positions) ---
# Comma-separated list of API keys (one per ~60 devices/min, per FRD FR-TRACK-004).
# Precedence: keys present → LIVE (always). Empty + FLEETHUNT_MOCK=true → MOCK
# (simulated fleet, no creds) for dev/UAT. Empty + no mock → OFF (cron skips).
# Keys ALWAYS win, so production with real keys can't get stuck on mock data.
FLEETHUNT_API_KEYS=
FLEETHUNT_MOCK=true
FLEETHUNT_BASE_URL=https://app.fleethunt.ca
# Governor tuning: max calls/min/key and back-off on 429/503.
FLEETHUNT_MAX_PER_MIN=60
FLEETHUNT_BACKOFF_MS=30000
# Polling cadence: FleetHunt cron runs every 60s (Vercel Cron min); UI refreshes
# from OUR DB every 30s at zero FleetHunt cost (FR-TRACK-002/003).
FLEETHUNT_POLL_MS=30000

# --- Vercel Cron auth ---
# Vercel sends `Authorization: Bearer $CRON_SECRET` to /api/cron/* when set.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Mapbox (map tiles + Directions API) ---
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- SendGrid (transactional email — CASL compliant) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=notifications@portal.udtl.ca

# --- Twilio (SMS notifications) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Sentry (error tracking, web + worker) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- hCaptcha (public tracking pages, per FRD FR-PUB-012) ---
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

# --- App config ---
# 'development' | 'staging' | 'production'
APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth hardening (Epic 1 / FR-AUTH) ---
# Idle session timeout in minutes (sliding window, enforced in middleware).
SESSION_IDLE_MINUTES=60
# Account lockout: N failed attempts within the window locks for that window.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
# When set, design supports staff step-up MFA (Supabase AAL2). No-op until enabled.
STAFF_MFA_REQUIRED=false

# --- SSO (Google / Microsoft — for ANY existing user; Meeting 4 flow) ---
# Users sign up with email+password first; SSO just validates the SSO email
# against an existing active DB user (no workspace restriction). Set to 'true'
# to show live SSO buttons.
NEXT_PUBLIC_SSO_ENABLED=false
# UDTL uses mixed mode (email/password + SSO). Keep false — true would disable
# password login (Load Assist's mode, not UDTL's).
SSO_ONLY_ENABLED=false
# OAuth client credentials. These are entered in the SUPABASE dashboard
# (Authentication → Providers → Google / Azure), not used directly by the app.
# Kept here for reference / scripts. Dev = company Load Assist creds; prod = UDTL's.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
