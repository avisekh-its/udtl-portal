# =================================================================
# UDTL Customer Portal & Operations Console — environment template
# =================================================================
# Copy this file to .env.local (web) and apps/worker/.env (worker).
# Never commit real values to git.
# =================================================================

# --- Supabase (DB + Auth + Storage) ---
# Project URL — looks like https://xxxxx.supabase.co
SUPABASE_URL=
# Anon (public) key — used in browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server only, NEVER exposed to client
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection (Drizzle migrations + worker)
DATABASE_URL=postgres://postgres:[password]@db.xxxxx.supabase.co:5432/postgres

# --- FleetHunt (live truck positions) ---
# Comma-separated list of API keys (one per ~30 devices, per FRD FR-TRACK-004)
FLEETHUNT_API_KEYS=
FLEETHUNT_BASE_URL=https://app.fleethunt.ca
# Polling cadence (ms) — default 30000 per FRD FR-TRACK-003
FLEETHUNT_POLL_MS=30000

# --- Mapbox (map tiles + Directions API) ---
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Resend (transactional email — CASL compliant) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@portal.udtl.ca

# --- Twilio (SMS notifications) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Sentry (error tracking, web + worker) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- hCaptcha (public tracking pages, per FRD FR-PUB-012) ---
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

# --- App config ---
# 'development' | 'staging' | 'production'
APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
