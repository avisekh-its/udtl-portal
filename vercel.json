{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build -w @udtl/web",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/.next",
  "regions": ["yul1"],
  "crons": [
    {
      "path": "/api/cron/poll-fleethunt",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "*/15 * * * *"
    }
  ]
}
